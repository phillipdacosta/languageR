# Mobile dev-only env overrides.
# Copy to `.env` and fill in the values you need. Only used in dev builds
# (when `__DEV__` is true). Production builds always use the values pinned
# in `src/config/env.ts`.

# Point the Expo dev client at a local backend instead of the deployed one.
# Use your laptop's LAN IP so a phone on the same Wi-Fi can reach it.
# EXPO_PUBLIC_API_BASE=http://192.168.1.10:3000

# Optional Auth0 overrides (useful when you spin up a sandbox tenant for dev).
# EXPO_PUBLIC_AUTH0_DOMAIN=
# EXPO_PUBLIC_AUTH0_CLIENT_ID=
# EXPO_PUBLIC_AUTH0_AUDIENCE=
