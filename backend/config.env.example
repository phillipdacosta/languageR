# Backend dev configuration template.
# Copy to `config.env` and fill in real values for local development. The
# server loads this file via `dotenv` at boot (see server.js).
# In production (Render), set these via the platform's env var dashboard
# instead of a file.

PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/yourDb?retryWrites=true&w=majority

# JWT for legacy `auth.js` middleware (separate from Auth0 — used by some
# self-issued tokens). Replace before deploying.
JWT_SECRET=replace-me

# Public web app origin — used for Stripe Connect return/refresh URLs and email links.
# Local: keep localhost. On Render, FRONTEND_URL is optional — the backend auto-uses
# FRONTEND_URL_DEV when RENDER=true unless FRONTEND_URL is set explicitly (e.g. barnabi.ai prod).
FRONTEND_URL=http://localhost:8100
FRONTEND_URL_DEV=https://languager-frontend.onrender.com
# Public frontend URL for email images/links when FRONTEND_URL is localhost (optional override)
# EMAIL_PUBLIC_FRONTEND_URL=https://app.barnabi.ai

# Card mascot images in booking emails are served from GCS (public HTTPS, works in Gmail).
# Override with EMAIL_ASSET_BASE_URL or EMAIL_MASCOT_GCS_BASE if needed.
# EMAIL_ASSET_BASE_URL=https://api.barnabi.ai/email-assets
# EMAIL_MASCOT_GCS_BASE=https://storage.googleapis.com/languager-videos-2025/email-assets
BACKEND_URL_DEV=https://api.barnabi.ai
PUBLIC_APP_URL=http://localhost:8100

# ── Auth0 ─────────────────────────────────────────────────────────────────
# verifyAuth.js uses these to verify JWT signatures via JWKS. Required in
# production. In dev, ALLOW_DEV_TOKENS lets the legacy `dev-token-{email}`
# shortcut keep working alongside real Auth0 verification.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.barnabi.com
AUTH0_CLIENT_ID=your-client-id
ALLOW_DEV_TOKENS=true

# ── Storage / media ───────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_BUCKET_NAME=
GOOGLE_CLOUD_KEY_FILE=
GCS_AUDIO_BACKUP_BUCKET=

# ── Agora video / whiteboard ──────────────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERT=
AGORA_WHITEBOARD_APP_ID=
AGORA_WHITEBOARD_AK=
AGORA_WHITEBOARD_SK=
AGORA_WHITEBOARD_REGION=us-sv

# ── AI services ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
FORCE_WHISPER_FAILURE=false
FORCE_GPT4_FAILURE=false

# ── Payments ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# ── Email / admin ─────────────────────────────────────────────────────────
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=

# SendGrid (transactional email — lesson booking confirmations, etc.)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Barnabi
SENDGRID_REPLY_TO_EMAIL=
SENDGRID_LESSON_BOOKED_TEMPLATE_ID=
# Optional separate SendGrid template for tutor booking emails (defaults to student template)
SENDGRID_LESSON_BOOKED_TUTOR_TEMPLATE_ID=
SUPPORT_EMAIL=support@barnabi.ai

# ── OAuth integrations ────────────────────────────────────────────────────
YOUTUBE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/auth/google-calendar/callback
# Public HTTPS URL of this backend, used for Google Calendar webhooks.
# Leave unset for local dev (falls back to polling).
# BACKEND_PUBLIC_URL=https://your-app.onrender.com

VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=
VIMEO_REDIRECT_URI=http://localhost:3000/api/auth/vimeo/callback
